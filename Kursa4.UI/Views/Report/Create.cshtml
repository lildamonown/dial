@model ReportForCreate

@{
	ViewData["Title"] = "Создание отчета";
	var originalPrice = ViewBag.OriginalPrice as double? ?? 0;
}

<div class="container mt-4">
	<h2>@ViewData["Title"]</h2>
	<hr />

	<div class="row">
		<div class="col-md-6">
			<form asp-action="Create" method="post" id="reportForm">
				<div asp-validation-summary="ModelOnly" class="text-danger"></div>

				<div class="mb-3">
					<div class="input-group">
						<input type="hidden" asp-for="OrderId" />
						<button type="button" class="btn btn-primary" id="orderInfoBtn" data-bs-toggle="modal" data-bs-target="#orderModal">
							<i class="bi bi-info-circle"></i> Инфо о заказе
						</button>
					</div>
					<span asp-validation-for="OrderId" class="text-danger"></span>
				</div>

				<div class="card mb-3">
					<div class="card-body">
						<div class="row">
							<div class="col-md-6">
								<small class="text-muted">Предварительная цена:</small>
								<p class="fs-5 mb-0">@originalPrice.ToString("N2") BYN</p>
							</div>
							<div class="col-md-6">
								<small class="text-muted">Разница:</small>
								<p class="fs-5 mb-0" id="priceDiff">0.00 BYN</p>
							</div>
						</div>
					</div>
				</div>

				<div class="mb-3">
					<label asp-for="FinitePrice" class="form-label"></label>
					<input asp-for="FinitePrice" class="form-control" id="finitePriceInput" />
					<span asp-validation-for="FinitePrice" class="text-danger"></span>
				</div>

				<div class="mb-3" id="commentSection" style="display: none;">
					<label asp-for="Comment" class="form-label"></label>
					<textarea asp-for="Comment" class="form-control" rows="3" placeholder="Укажите причину изменения цены..."></textarea>
					<span asp-validation-for="Comment" class="text-danger"></span>
					<small class="text-muted">Укажите причину, если финальная цена отличается от предварительной</small>
				</div>

				<div class="mb-3">
					<label asp-for="NameMaster" class="form-label"></label>
					<input asp-for="NameMaster" class="form-control" />
					<span asp-validation-for="NameMaster" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="SurnameMaster" class="form-label"></label>
					<input asp-for="SurnameMaster" class="form-control" />
					<span asp-validation-for="SurnameMaster" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<button type="submit" class="btn btn-success">Создать отчет</button>
					<a asp-action="Index" class="btn btn-secondary">Отмена</a>
				</div>
			</form>
		</div>
	</div>
</div>

<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-lg">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="orderModalLabel">Информация о заказе #<span id="modalOrderId"></span></h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body" id="orderDetailsContent">
				<div class="text-center">
					<div class="spinner-border text-primary" role="status">
						<span class="visually-hidden">Загрузка...</span>
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
			</div>
		</div>
	</div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
	var originalPrice = @originalPrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

	function updatePriceDiff() {
		var finite = parseFloat($('#finitePriceInput').val()) || 0;
		var diff = finite - originalPrice;
		var diffStr = (diff >= 0 ? '+' : '') + diff.toFixed(2) + ' BYN';
		var el = $('#priceDiff');
		el.text(diffStr);
		el.removeClass('text-success text-danger');
		if (diff > 0) el.addClass('text-danger');
		else if (diff < 0) el.addClass('text-success');
		else el.addClass('text-muted');

		if (Math.abs(diff) > 0.01) {
			$('#commentSection').slideDown();
		} else {
			$('#commentSection').slideUp();
		}
	}

	$(document).ready(function() {
		$('#finitePriceInput').on('input', updatePriceDiff);
		updatePriceDiff();
		$('#orderInfoBtn').click(function() {
			const orderId = $('#OrderId').val();

			$('#modalOrderId').text(orderId);

			$.get('/Order/GetById', { orderId: orderId })
				.done(function(response) {
					if (response.success) {
						const order = response.order;
						$('#orderDetailsContent').html(`
							<div class="row mb-3">
								<div class="col-md-6">
									<p><strong>Клиент:</strong> ${order.userName} ${order.userSurname}</p>
									<p class="text-dark"><strong>Телефон:</strong> ${order.userPhoneNumber}</p>
								</div>
								<div class="col-md-6">
									<p><strong>Дата создания:</strong> ${new Date(order.createAt).toLocaleString()}</p>
									<p><strong>Предварительная цена:</strong> ${order.sumPrice.toFixed(2)}</p>
								</div>
							</div>
							<div class="row">
								<div class="col-12">
									<h6>Подуслуги:</h6>
									<ul class="list-group">
										${order.nameSubservice.map(sub => `<li class="list-group-item">${sub}</li>`).join('')}
									</ul>
								</div>
							</div>
						`);
					} else {
						$('#orderDetailsContent').html(`
							<div class="alert alert-danger">
								${response.message || 'Произошла ошибка при получении данных о заказе'}
							</div>
						`);
					}
				})
				.fail(function() {
					$('#orderDetailsContent').html(`
						<div class="alert alert-danger">
							Ошибка соединения с сервером
						</div>
					`);
				});
		});

		// Очищаем модальное окно при закрытии
		$('#orderModal').on('hidden.bs.modal', function () {
			$('#orderDetailsContent').html(`
				<div class="text-center">
					<div class="spinner-border text-primary" role="status">
						<span class="visually-hidden">Загрузка...</span>
					</div>
				</div>
			`);
		});
	});
</script>
