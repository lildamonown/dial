@model List<ReportModel>

@{
	ViewData["Title"] = "Отчеты";
}

<div class="container mt-4">
	<h2 class="mb-4">@ViewData["Title"]</h2>

	<div class="row mb-4">
		<div class="col-md-8">
			<form method="get" class="row g-3">
				<div class="col-md-4">
					<select class="form-select" name="month">
						@for (int m = 1; m <= 12; m++)
						{
							<option value="@m" selected="@(m == ViewBag.SelectedMonth ? true : null)">
								@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)
							</option>
						}
					</select>
				</div>
				<div class="col-md-4">
					<select class="form-select" name="year">
						@for (int y = 2024; y <= DateTime.Now.Year; y++)
						{
							<option value="@y" selected="@(y == ViewBag.SelectedYear ? true : null)">@y</option>
						}
					</select>
				</div>
				<div class="col-md-4">
					<button type="submit" class="btn btn-primary">Показать</button>
					<a asp-action="Index" class="btn btn-secondary">Сброс</a>
				</div>
			</form>
		</div>
	</div>

	<table class="table table-striped table-hover">
		<thead class="table-dark">
			<tr>
				<th style="width: 40px;"></th>
				<th>№</th>
				<th>Статус</th>
				<th>Клиент</th>
				<th>Авто</th>
				<th>Подуслуги</th>
				<th>Финальная цена</th>
				<th>Дата завершения</th>
				<th>Мастер</th>
				<th>Комментарий</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var item in Model)
			{
				<tr>
					<td>
						<button type="button" class="btn btn-sm btn-outline-primary order-info-toggle"
								data-order-id="@item.OrderId">
							<i class="bi bi-info-circle"></i>
						</button>
					</td>
					<td>@item.OrderId</td>
					<td>@item.StatusName</td>
					<td>
						<strong>@item.ClientName</strong><br />
						<small class="text-muted">@item.ClientPhone</small>
					</td>
					<td>@item.CarMark</td>
					<td>
						@if (item.OrderSubservices.Any())
						{
							<ul class="list-unstyled mb-0">
								@foreach (var sub in item.OrderSubservices)
								{
									<li><small>@sub</small></li>
								}
							</ul>
						}
						else
						{
							<span class="text-muted">—</span>
						}
					</td>
					<td class="fw-bold">@item.FinitePrice.ToString("N2") BYN</td>
					<td>@item.DateCompleted.ToString("dd.MM.yyyy HH:mm")</td>
					<td>@item.NameMaster @item.SurnameMaster</td>
					<td>
						@if (!string.IsNullOrEmpty(item.Comment))
						{
							<small>@item.Comment</small>
						}
						else
						{
							<span class="text-muted fst-italic">—</span>
						}
					</td>
				</tr>
				<tr class="order-details-row" style="display:none;" data-order-id="@item.OrderId">
					<td colspan="10">
						<div class="p-3 bg-light">
							<div class="text-center">
								<div class="spinner-border text-primary" role="status">
									<span class="visually-hidden">Загрузка...</span>
								</div>
							</div>
						</div>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
	$(document).ready(function() {
		$('.order-info-toggle').click(function() {
			const orderId = $(this).data('order-id');
			const row = $(`.order-details-row[data-order-id="${orderId}"]`);

			if (row.is(':visible')) {
				row.hide();
				return;
			}

			row.show();

			$.get('/Order/GetById', { orderId: orderId })
				.done(function(response) {
					if (response.success) {
						const order = response.order;
						row.find('td > div').html(`
							<div class="row">
								<div class="col-12">
									<p><strong>Клиент:</strong> ${order.userName} ${order.userSurname} <span class="text-muted">${order.userPhoneNumber}</span></p>
									<p><strong>Дата создания:</strong> ${new Date(order.createAt).toLocaleString()}</p>
									<p><strong>Статус:</strong> ${order.statusName || ''}</p>
									<p><strong>Предварительная цена:</strong> ${order.sumPrice.toFixed(2)} BYN</p>
									<h6>Подуслуги:</h6>
									<ul class="list-group">
										${order.nameSubservice.map(sub => `<li class="list-group-item">${sub}</li>`).join('')}
									</ul>
								</div>
							</div>
						`);
					} else {
						row.find('td > div').html(`<div class="alert alert-danger mb-0">${response.message || 'Ошибка загрузки'}</div>`);
					}
				})
				.fail(function() {
					row.find('td > div').html(`<div class="alert alert-danger mb-0">Ошибка соединения</div>`);
				});
		});
	});
</script>