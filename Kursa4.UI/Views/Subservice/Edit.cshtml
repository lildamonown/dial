@model SubserviceForEdit

@{
	ViewData["Title"] = "Редактирование подуслуги";
}

<div class="container mt-4">
	<h2>@ViewData["Title"]</h2>
	<hr />

	<form asp-action="Edit" method="post" class="needs-validation" novalidate>
		<input type="hidden" asp-for="Id" />

		<div class="row">
			<div class="col-md-8">
				<div class="mb-3">
					<label class="form-label">Родительская услуга</label>
					<select asp-for="ServiceId"
							asp-items="@(ViewBag.Services)"
							class="form-select">
					</select>
					<input asp-for="ServiceId" id="val-select" hidden />
					<span asp-validation-for="ServiceId" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="Name" class="form-label"></label>
					<input asp-for="Name" class="form-control" />
					<span asp-validation-for="Name" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="Description" class="form-label"></label>
					<textarea asp-for="Description" class="form-control" rows="4"></textarea>
					<span asp-validation-for="Description" class="text-danger"></span>
				</div>

				<div class="row">
					<div class="col-md-5 mb-3">
						<label class="form-label">Срок выполнения</label>
						<div class="input-group">
							<input asp-for="LeadTimeDays" class="form-control" placeholder="Дни" />
							<span class="input-group-text">дн.</span>
							<input asp-for="LeadTimeHours" class="form-control" placeholder="Часы" />
							<span class="input-group-text">ч.</span>
							<input asp-for="LeadTimeMinutes" class="form-control" placeholder="Мин." />
							<span class="input-group-text">м.</span>
						</div>
						<span asp-validation-for="LeadTimeDays" class="text-danger"></span>
						<span asp-validation-for="LeadTimeHours" class="text-danger"></span>
						<span asp-validation-for="LeadTimeMinutes" class="text-danger"></span>
					</div>

					<div class="col-md-6 mb-3">
						<label asp-for="Price" class="form-label"></label>
						<div class="input-group">
							<input asp-for="Price" class="form-control" type="number" step="0.01" id="priceInput" />
							<span class="input-group-text">BYN</span>
						</div>
						<span asp-validation-for="Price" class="text-danger"></span>
					</div>
				</div>

				<div class="mb-3" id="priceCommentSection" style="display: none;">
					<label asp-for="PriceComment" class="form-label"></label>
					<textarea asp-for="PriceComment" class="form-control" rows="3" placeholder="Укажите причину изменения цены..."></textarea>
					<span asp-validation-for="PriceComment" class="text-danger"></span>
					<small class="text-muted">Обязательно укажите причину при изменении цены</small>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card">
					<div class="card-body">
						<h5 class="card-title">Настройки</h5>

						<div class="form-check form-switch mb-3">
							<input class="form-check-input" type="checkbox" asp-for="FixPrice" />
							<label class="form-check-label" asp-for="FixPrice"></label>
						</div>

						<div class="form-check form-switch mb-3">
							<input class="form-check-input" type="checkbox" asp-for="Visible" />
							<label class="form-check-label" asp-for="Visible"></label>
						</div>

						<div class="d-grid gap-2">
							<button type="submit" class="btn btn-primary" onclick="console.log('Submitting ServiceId:', document.querySelector('#ServiceId').value);">Сохранить</button>
							<a href="@Url.Action("Index", "Service")" class="btn btn-secondary">Отмена</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</form>
</div>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const priceInput = document.getElementById('priceInput');
		const commentSection = document.getElementById('priceCommentSection');
		const originalPrice = priceInput.value;

		priceInput.addEventListener('input', function() {
			if (this.value !== originalPrice) {
				commentSection.style.display = 'block';
			} else {
				commentSection.style.display = 'none';
			}
		});
	});
</script>
