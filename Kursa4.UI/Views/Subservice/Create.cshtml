@model SubserviceForCreate

@{
    ViewData["Title"] = "Создание подуслуги";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>
    <hr />

    <form asp-action="Create" method="post" class="needs-validation" novalidate>
        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label class="form-label">Родительская услуга</label>
                    <select asp-for="ServiceId"
                            asp-items="@(ViewBag.Services)"
                            class="form-select">
                    </select>
                    <input asp-for="ServiceId" id="val-select" hidden />
                    <span asp-validation-for="ServiceId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Срок выполнения</label>
                        <div class="input-group">
                            <input asp-for="LeadTimeDays" class="form-control" placeholder="Дни" max="365"/>
                            <span class="input-group-text">дн.</span>
                            <input asp-for="LeadTimeHours" class="form-control" placeholder="Часы" max="23"/>
                            <span class="input-group-text">ч.</span>
                            <input asp-for="LeadTimeMinutes" class="form-control" placeholder="Мин." max="59" />
                            <span class="input-group-text">м.</span>
                        </div>
                        <span asp-validation-for="LeadTimeDays" class="text-danger"></span>
                        <span asp-validation-for="LeadTimeHours" class="text-danger"></span>
                        <span asp-validation-for="LeadTimeMinutes" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                            <span class="input-group-text">BYN</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Настройки</h5>

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="FixPrice" />
                            <label class="form-check-label" asp-for="FixPrice"></label>
                        </div>

                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="Visible" checked />
                            <label class="form-check-label" asp-for="Visible"></label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Создать</button>
                            <a asp-action="Index" asp-controller="Service" class="btn btn-secondary">Отмена</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
       document.addEventListener('DOMContentLoaded', function() {
        const timeInputs = document.querySelectorAll('.input-group input[type="number"]');

        timeInputs.forEach(input => {
            input.addEventListener('input', function() {
                const max = parseInt(this.getAttribute('max')) || Infinity;
                const min = parseInt(this.getAttribute('min')) || 0;
                let value = parseInt(this.value) || 0;

                if (value > max) {
                    value = max;
                    this.value = value;
                } else if (value < min) {
                    value = min;
                    this.value = value;
                }

                if (this.value.startsWith('-')) {
                    this.value = this.value.replace('-', '');
                }
            });

            input.addEventListener('blur', function() {
                if (this.value === "") {
                    this.value = this.getAttribute('min') || "0";
                }
            });
        });
    });
</script>