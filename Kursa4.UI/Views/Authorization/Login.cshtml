@model UserLogin;

@{
	ViewData["Title"] = "Вход";
}

<main class="form-signin w-25 m-auto">
	<form method="post" asp-controller="Authorization" asp-action="Login">
		<div asp-validation-summary="ModelOnly" class="text-danger"></div>
		<h1 class="h3 mb-3 fw-normal">Вход</h1>

		<div class="form-floating">
			<input asp-for="Email" type="email" class="form-control" id="floatingInput" placeholder="name@example.com">
			<label asp-for="Email" for="floatingInput">Логин</label>
		</div>
		<div class="form-floating mt-3">
			<input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Пароль">
			<label asp-for="Password" for="floatingPassword">Пароль</label>
			<button type="button"
					class="btn btn-outline-secondary position-absolute end-0 top-0 h-80 border-0 output-password"
					onmousedown="showPassword('floatingPassword', this)"
					onmouseup="hidePassword('floatingPassword', this)"
					onmouseleave="hidePassword('floatingPassword', this)"
					ontouchstart="showPassword('floatingPassword', this)"
					ontouchend="hidePassword('floatingPassword', this)">
				<i class="bi bi-eye"></i>
			</button>
		</div>

		<div class="checkbox mb-3 mt-3">
			<label>
				<input type="checkbox" value="remember-me"> Запомнить?
			</label>
		</div>
		<button class="w-100 btn btn-lg btn-primary" type="submit">Вход</button>
	</form>
</main>
