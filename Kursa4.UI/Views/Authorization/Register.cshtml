@model Kursa4.UI.Models.Inputs.UserRegister;

@{
    ViewData["Title"] = "Регистрация";
}

<div class="form-register w-50 m-auto">
    <form method="post" asp-controller="Authorization" asp-action="Register" class="p-4 border rounded">
        <div asp-validation-summary="ModelOnly"></div>
        <h1 class="h3 mb-3 fw-normal text-center">Регистрация</h1>

        <div class="form-floating mb-3">
            <input asp-for="Email" type="email" class="form-control" id="email" placeholder="name@@example.com">
            <label asp-for="Email" for="email">Логин</label>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col">
                <div class="form-floating mb-3">
                    <input asp-for="FirstName" type="text" class="form-control" id="firstName" placeholder="Иван">
                    <label asp-for="FirstName" for="firstName">Имя</label>
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <input asp-for="Surname" type="text" class="form-control" id="surname" placeholder="Иванов">
                    <label asp-for="Surname" for="surname">Фамилия</label>
                    <span asp-validation-for="Surname" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="PhoneNumber" type="tel" class="form-control" id="phoneNumber" placeholder="+375291234567">
            <label asp-for="PhoneNumber" for="phoneNumber">Номер телефона</label>
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col">
                <div class="form-floating mb-3 position-relative">
                    <input asp-for="Password" type="password" class="form-control pe-5" id="password" placeholder="Пароль">
                    <label asp-for="Password" for="password">Пароль</label>
                    <button type="button"
                            class="btn btn-outline-secondary position-absolute end-0 top-0 h-80 border-0 output-password"
                            onmousedown="showPassword('password', this)"
                            onmouseup="hidePassword('password', this)"
                            onmouseleave="hidePassword('password', this)"
                            ontouchstart="showPassword('password', this)"
                            ontouchend="hidePassword('password', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                    <span asp-validation-for="Password" class="text-danger"></span>
                    <div id="password-strength" class="mt-2 small">
                        <div class="progress mb-1" style="height: 4px;">
                            <div id="strength-bar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <ul class="list-unstyled mb-0" id="password-requirements">
                            <li id="req-length" class="text-muted"><i class="bi bi-circle me-1"></i>Не менее 6 символов</li>
                            <li id="req-upper" class="text-muted"><i class="bi bi-circle me-1"></i>Заглавная буква (A-Z)</li>
                            <li id="req-lower" class="text-muted"><i class="bi bi-circle me-1"></i>Строчная буква (a-z)</li>
                            <li id="req-digit" class="text-muted"><i class="bi bi-circle me-1"></i>Цифра (0-9)</li>
                            <li id="req-special" class="text-muted"><i class="bi bi-circle me-1"></i>Спецсимвол (!@@#$%^&*)</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <input asp-for="PasswordConfirm" type="password" class="form-control" id="confirmPassword" placeholder="Повторите пароль">
                    <label asp-for="PasswordConfirm" for="confirmPassword">Повторите пароль</label>
                    <span asp-validation-for="PasswordConfirm" class="text-danger"></span>
                </div>
            </div>
        </div>

        <button class="w-100 btn btn-lg btn-primary" type="submit">Зарегистрироваться</button>
    </form>
</div>

<script>
    document.getElementById('password').addEventListener('input', function() {
        const pwd = this.value;
        const checks = {
            length: pwd.length >= 6,
            upper: /[A-Z]/.test(pwd),
            lower: /[a-z]/.test(pwd),
            digit: /\d/.test(pwd),
            special: /[!@@#$%^&*(),.?":{}|<>]/.test(pwd)
        };

        const passed = Object.values(checks).filter(Boolean).length;
        const pct = (passed / Object.keys(checks).length) * 100;

        const bar = document.getElementById('strength-bar');
        bar.style.width = pct + '%';
        bar.setAttribute('aria-valuenow', pct);
        bar.className = 'progress-bar';
        if (pct <= 40) bar.classList.add('bg-danger');
        else if (pct <= 60) bar.classList.add('bg-warning');
        else if (pct <= 80) bar.classList.add('bg-info');
        else bar.classList.add('bg-success');

        const icons = { length: 'req-length', upper: 'req-upper', lower: 'req-lower', digit: 'req-digit', special: 'req-special' };
        for (const [key, id] of Object.entries(icons)) {
            const el = document.getElementById(id);
            if (checks[key]) {
                el.className = 'text-success';
                el.querySelector('i').className = 'bi bi-check-circle-fill me-1';
            } else {
                el.className = 'text-muted';
                el.querySelector('i').className = 'bi bi-circle me-1';
            }
        }
    });
</script>
