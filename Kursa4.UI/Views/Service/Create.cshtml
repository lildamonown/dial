@model ServiceForCreate

@{
    ViewData["Title"] = "Добавление услуги";
}

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>
    <hr />

    <form asp-action="Create" method="post" class="needs-validation" novalidate>
        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="Visible" />
                    <label class="form-check-label" asp-for="Visible"></label>
                </div>

                <div class="d-grid gap-2 d-md-block">
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                    <a href="@Url.Action("Index", "Service")" class="btn btn-secondary">Отмена</a>
                </div>
            </div>
        </div>
    </form>
</div>