@model OrderForEdit

<div class="container mt-4">
	<h2>@ViewData["Title"]</h2>
	<hr />
	<form asp-action="Edit" method="post" class="needs-validation" novalidate>
		<div asp-validation-summary="ModelOnly" class="text-danger"></div>
		<input type="hidden" asp-for="Id" />
		<input type="hidden" asp-for="UserId" />
		<input type="hidden" asp-for="CarId" />
		<input type="hidden" asp-for="CreateAt" />

		<div class="row">
			<div class="col-md-6">
				<div class="card">
					<div class="card-header">
						<h5 class="card-title">Выбор подуслуг*</h5>
					</div>
					<div class="card-body">
						<div id="subservices-container" class="mb-3">
							<!-- Сюда будут добавляться выбранные подуслуги -->
							@for (var i = 0; i < Model.Subservices.Count; i++)
							{
								<div class="card mb-2 subservice-item" data-id="@Model.Subservices[i].Id">
									<div class="card-body py-2">
										<div class="d-flex justify-content-between align-items-center">
											<div>
												<h6 class="mb-0">@Model.Subservices[i].Name</h6>
												<small class="text-muted">@Model.Subservices[i].Price.ToString("0.00") BYN</small>
											</div>
											@if (User.IsInRole("Master"))
											{
												<button type="button" class="btn btn-sm btn-danger remove-subservice">
													<i class="bi bi-trash"></i>
												</button>
											}
										</div>
										<input type="hidden" name="Subservices[@i].Id" value="@Model.Subservices[i].Id" />
										<input type="hidden" name="Subservices[@i].Name" value="@Model.Subservices[i].Name" />
										<input type="hidden" name="Subservices[@i].Price" value="@Model.Subservices[i].Price.ToString().Replace(",", ".")" />
									</div>
								</div>
							}
						</div>
						@if (User.IsInRole("Master"))
						{
							<button type="button" class="btn btn-primary" id="add-subservice">
								Добавить подуслугу
							</button>
						}
						<span asp-validation-for="Subservices" class="text-danger d-block mt-2"></span>
					</div>
				</div>
			</div>
			<div class="col-md-3">
				<div class="mb-3">
					<label asp-for="VisitDate" class="form-label"></label>
					<input asp-for="VisitDate" type="datetime-local"
						   class="form-control" min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
					<span asp-validation-for="VisitDate" class="text-danger"></span>
				</div>
				<div class="mb-3">
					<label class="form-label">Статус</label>
					<select asp-for="StatusId"
							asp-items="@(ViewBag.Statuses)"
							class="form-select">
					</select>
					<input asp-for="StatusId" id="val-select" hidden />
					<span asp-validation-for="StatusId" class="text-danger"></span>
				</div>
			</div>
		</div>
		<div class="mt-3">
			<button type="submit" class="btn btn-success">Сохранить изменения</button>
			<a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Отмена</a>
		</div>
	</form>
</div>

@section Scripts {
	<script>
		$(document).ready(function() {
			// Модальное окно для выбора подуслуг
			$('#add-subservice').click(function() {
				$.get('/Subservice/GetAll', function(data) {
					if (data.success) {
						let modalHtml = `
							<div class="modal fade" id="subserviceModal" tabindex="-1">
								<div class="modal-dialog modal-lg">
									<div class="modal-content">
										<div class="modal-header">
											<h5 class="modal-title">Выберите подуслуги</h5>
											<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
										</div>
										<div class="modal-body">
											<table class="table">
												<thead>
													<tr>
														<th>Выбрать</th>
														<th>Название</th>
														<th>Цена</th>
													</tr>
												</thead>
												<tbody>`;

						data.subservices.forEach(sub => {
							// Проверяем, не выбрана ли уже эта подуслуга
							const isSelected = $('.subservice-item[data-id="' + sub.id + '"]').length > 0;

							modalHtml += `
								<tr>
									<td><input type="checkbox" class="subservice-check"
											data-id="${sub.id}"
											data-name="${sub.name}"
											data-price="${sub.price.toString().replace(',', '.')}"
											data-leadtime="${sub.leadTime}"
											${isSelected ? 'disabled' : ''} /></td>
									<td>${sub.name}</td>
									<td>${sub.price.toLocaleString('ru-RU', {minimumFractionDigits: 2})} BYN</td>
								</tr>`;
						});

						modalHtml += `
												</tbody>
											</table>
										</div>
										<div class="modal-footer">
											<button type="button" class="btn btn-primary"
												id="confirm-subservices">Добавить</button>
											<button type="button" class="btn btn-secondary"
												data-bs-dismiss="modal">Отмена</button>
										</div>
									</div>
								</div>
							</div>`;

						$('body').append(modalHtml);
						var modal = new bootstrap.Modal(document.getElementById('subserviceModal'));
						modal.show();

						$('#confirm-subservices').click(function() {
							$('.subservice-check:checked').each(function() {
								const priceStr = $(this).attr('data-price');
								const sub = {
									id: $(this).data('id'),
									name: $(this).data('name'),
									price: parseFloat(priceStr.replace(',', '.')),
									leadTime: $(this).data('leadtime')
								};
								addSubserviceToForm(sub);
							});
							modal.hide();
						});

						$('#subserviceModal').on('hidden.bs.modal', function () {
							$(this).remove();
						});
					}
				});
			});

			function addSubserviceToForm(subservice) {
				const container = $('#subservices-container');
				const index = container.children().length;

				const html = `
					<div class="card mb-2 subservice-item" data-id="${subservice.id}">
						<div class="card-body py-2">
							<div class="d-flex justify-content-between align-items-center">
								<div>
									<h6 class="mb-0">${subservice.name}</h6>
									<small class="text-muted">${subservice.price.toFixed(2)} BYN</small>
								</div>
								<button type="button" class="btn btn-sm btn-danger remove-subservice">
									<i class="bi bi-trash"></i>
								</button>
							</div>
							<input type="hidden" name="Subservices[${index}].Id" value="${subservice.id}" />
							<input type="hidden" name="Subservices[${index}].Name" value="${subservice.name}" />
							<input type="hidden" name="Subservices[${index}].Price" value="${subservice.price.toString().replace('.', ',')}" />
						</div>
					</div>`;

				container.append(html);

				// Обновляем валидацию
				const form = container.closest('form');
				form.removeClass('was-validated');
				form.addClass('was-validated');
			}

			$(document).on('click', '.remove-subservice', function() {
				$(this).closest('.subservice-item').remove();
				reindexSubservices();
			});

			function reindexSubservices() {
				$('#subservices-container .subservice-item').each(function(index) {
					$(this).find('input').each(function() {
						const name = $(this).attr('name').replace(/\[\d+\]/, `[${index}]`);
						$(this).attr('name', name);
					});
				});
			}
		});
	</script>
}